{
  "name": "moss",
  "version": "0.9.0-beta.6",
  "description": "MOSS — Modular Operating System for Self",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/braxtonhughes360-ship-it/mossprint.git"
  },
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "lint": "tsc -p tsconfig.web.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps && node scripts/fetch-cabinet-fonts.mjs",
    "fonts:fetch": "node scripts/fetch-cabinet-fonts.mjs",
    "icon:render": "env -u ELECTRON_RUN_AS_NODE electron scripts/render-app-icon.mjs",
    "icon:tray": "env -u ELECTRON_RUN_AS_NODE electron scripts/render-tray-icon.mjs",
    "runtime:fetch": "node scripts/fetch-local-runtime.mjs",
    "runtime:fetch:mac": "node scripts/fetch-local-runtime.mjs --target=darwin-arm64 && node scripts/fetch-local-runtime.mjs --target=darwin-x64",
    "runtime:fetch:all": "node scripts/fetch-local-runtime.mjs --all",
    "oauth:encrypt": "node scripts/encrypt-google-oauth.mjs",
    "package": "npm run build && npm run runtime:fetch && electron-builder --dir",
    "package:mac": "npm run build && npm run runtime:fetch:mac && electron-builder --mac --dir",
    "verify:db": "npm run build && node scripts/verify-database.mjs",
    "verify:db:packaged": "node scripts/verify-database.mjs",
    "verify:ledger": "npm run build && node scripts/verify-ledger-v2e.mjs",
    "verify:import": "npm run build && node scripts/verify-import-v2f.mjs",
    "verify:credit": "npm run build && node scripts/verify-credit-cards.mjs",
    "verify:flow": "npm run build && node scripts/verify-flow-v2c.mjs",
    "verify:nutrition-qa": "node scripts/nutrition-qa-checklist.mjs",
    "verify:describe-parse": "npm run build && node scripts/verify-describe-parse.mjs",
    "verify:capture-routing": "npm run build && node scripts/verify-capture-routing.mjs",
    "perf:sweep": "node scripts/measure-perf-sweep.mjs",
    "nutrition:import-usda": "npm run build && node scripts/import-usda-foundation.mjs",
    "verify:describe": "npm run build && node scripts/verify-describe-smoke.mjs",
    "verify:estimate-labels": "npm run build && node scripts/verify-estimate-labels.mjs",
    "verify:calendar-parse": "npm run build && node scripts/verify-calendar-parse.mjs",
    "verify:news-offline": "npm run build && node scripts/verify-news-offline.mjs",
    "verify:calendar-qa": "node scripts/calendar-qa-checklist.mjs",
    "verify:contrast": "node scripts/verify-theme-contrast.mjs",
    "moss:wipe-profiles": "node scripts/wipe-profiles.mjs",
    "seed:qa": "npm run build && node scripts/seed-qa-profile.mjs",
    "shots:readme": "npm run build && node scripts/capture-readme-shots.mjs",
    "shots:audit": "npm run build && MOSS_SHOTS_FULL=1 node scripts/capture-readme-shots.mjs",
    "shots:beta6-w3d": "npm run build && MOSS_SHOTS_FRESH=1 node scripts/capture-readme-shots.mjs",
    "shots:beta6-w3b": "npm run build && MOSS_SHOTS_W3B=1 MOSS_HEADLESS_LOADING_DELAY_MS=1800 node scripts/capture-readme-shots.mjs",
    "shots:beta6-w2i": "npm run build && MOSS_SHOTS_W2I=1 node scripts/capture-readme-shots.mjs",
    "smoke:qa2": "npm run build && node scripts/qa2-resmoke.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@radix-ui/react-dismissable-layer": "^1.1.14",
    "@radix-ui/react-focus-scope": "^1.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.2",
    "better-sqlite3-multiple-ciphers": "^12.11.1",
    "electron-updater": "^6.8.9",
    "googleapis": "^173.0.0",
    "imapflow": "^1.4.2",
    "mailparser": "^3.9.11",
    "motion": "^12.40.0",
    "node-ical": "^0.26.1",
    "nodemailer": "^9.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "suncalc": "^2.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^42.5.2",
    "electron-builder": "^26.15.6",
    "electron-vite": "^3.1.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "r3f-perf": "^7.2.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.moss.app",
    "productName": "MOSS",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": ".",
        "filter": [
          "google-oauth.json",
          "google-oauth.enc.json"
        ]
      },
      {
        "from": "build/trayTemplate.png",
        "to": "."
      },
      {
        "from": "build/trayIcon.png",
        "to": "."
      },
      {
        "from": "build/runtime/${platform}-${arch}",
        "to": "llama-runtime"
      }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3-multiple-ciphers/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "braxtonhughes360-ship-it",
      "repo": "mossprint",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "StateZero <braxtonhughes360-ship-it@users.noreply.github.com>"
    }
  }
}
